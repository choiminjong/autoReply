# === Microsoft Graph API ===
CLIENT_ID=c82cb0ff-6093-4bcd-a654-18942bdf5e8d
TENANT_ID=558a3344-3004-4f39-816f-4dfa342d9d5f
# CLIENT_SECRET는 선택사항 (공개 클라이언트 흐름 사용 시 비워두세요)
CLIENT_SECRET=
# Azure Portal에서 반드시 등록: http://localhost:8000/api/outlook/callback
REDIRECT_URI=http://localhost:8000/api/outlook/callback

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/emails.db
# true=서비스 시작 시 자동 마이그레이션 | false=운영(수동 alembic upgrade head --sql)
AUTO_MIGRATE=true

# === Security ===
# setup.sh 실행 시 자동 생성됩니다 (32 bytes, base64 인코딩)
ENCRYPTION_KEY=

# === App ===
HOST=0.0.0.0
PORT=8000
POLL_INTERVAL_SECONDS=180
